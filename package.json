{
  "name": "personal-otp-vault",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:extension-lib": "node ./scripts/sync-extension-lib.mjs",
    "serve:test": "http-server . -p 4173 -c-1 --silent",
    "test:unit": "npm run sync:extension-lib && vitest run",
    "test:e2e": "npm run sync:extension-lib && playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "http-server": "^14.1.1",
    "vitest": "^3.2.4"
  }
}
